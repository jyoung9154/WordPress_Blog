# ==============================================================================
# Git Ignore 파일
# ==============================================================================

# 환경변수 파일 (보안)
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docker
*.log

# Logs
logs/*.log
logs/*.log.*

# Output
output/*
!output/.gitkeep

# Backup
backup/*
!backup/.gitkeep

# SSL Certificates
nginx/ssl/*.pem
!nginx/ssl/README.md

# Temporary files
*.tmp
*.temp
