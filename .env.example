# ==============================================================================
# AI 자동화 영어 금융 블로그 시스템 - 환경변수 설정 파일
# ==============================================================================
# 이 파일의 역할: 모든 민감한 설정값과 API 키를 환경변수로 관리
# 사용법: cp .env.example .env 후 실제 값으로 수정
# 중요: .env 파일은 절대 Git에 커밋하지 마세요!
# ==============================================================================

# -----------------------------------------------------------------------------
# AI 프로바이더 설정 (여러 프로바이더 동시 설정 가능)
# -----------------------------------------------------------------------------
# 사용할 AI 프로바이더 선택: claude, openai, gemini, groq, ollama
AI_PROVIDER=claude

# Claude API (Anthropic) - https://console.anthropic.com/
CLAUDE_API_KEY=여기에_Claude_API_키_입력
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI API (대체용) - https://platform.openai.com/
OPENAI_API_KEY=여기에_OpenAI_API_키_입력
OPENAI_MODEL=gpt-4o

# Google Gemini API - https://aistudio.google.com/
GEMINI_API_KEY=여기에_Gemini_API_키_입력
GEMINI_MODEL=gemini-pro

# Groq API (무료/low-cost) - https://console.groq.com/
GROQ_API_KEY=여기에_Groq_API_키_입력
GROQ_MODEL=mixtral-8x7b-32768

# Ollama (로컬 AI) - https://ollama.ai/
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# LiteLLM 프록시 서버 (NVIDIA API 등)
LITELLM_BASE_URL=http://100.82.150.90:4000
LITELLM_MODEL=glm-plan

# -----------------------------------------------------------------------------
# MySQL 데이터베이스 설정
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=여기에_안전한_루트_비밀번호_입력
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=여기에_데이터베이스_사용자_비밀번호_입력

# -----------------------------------------------------------------------------
# WordPress 설정
# -----------------------------------------------------------------------------
WORDPRESS_URL=https://your-domain.com
WORDPRESS_TITLE=AI Finance Blog
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=여기에_관리자_비밀번호_입력
WORDPRESS_ADMIN_EMAIL=admin@your-domain.com

# -----------------------------------------------------------------------------
# WordPress REST API 설정
# -----------------------------------------------------------------------------
WP_SITE_URL=https://your-domain.com
WP_API_USERNAME=여기에_WordPress_사용자명_입력
WP_API_PASSWORD=여기에_WordPress_애플리케이션_비밀번호_입력
# 애플리케이션 비밀번호 생성: WordPress 관리자 > 사용자 > 프로필 > 애플리케이션 비밀번호

# -----------------------------------------------------------------------------
# n8n 오토메이션 설정
# -----------------------------------------------------------------------------
N8N_USER=n8n_admin
N8N_PASSWORD=여기에_n8n_비밀번호_입력
N8N_HOST=your-domain.com
N8N_WEBHOOK_URL=https://your-domain.com/webhook/

# -----------------------------------------------------------------------------
# Unsplash API (무료 Featured Image용)
# -----------------------------------------------------------------------------
UNSPLASH_ACCESS_KEY=여기에_Unsplash_Access_Key_입력
# https://unsplash.com/developers 에서 무료로 신청

# -----------------------------------------------------------------------------
# 제휴 링크 설정
# -----------------------------------------------------------------------------
# 각 제휴 프로그램의 리프레럴/제휴 링크를 입력
M1_FINANCE_AFFILIATE_LINK=https://m1.com/r/your-affiliate-id
ACORNS_AFFILIATE_LINK=https://acorns.com/r/your-affiliate-id
BETTERMENT_AFFILIATE_LINK=https://betterment.com/r/your-affiliate-id
VANGUARD_AFFILIATE_LINK=
TURBOTAX_AFFILIATE_LINK=
CREDIT_KARMA_AFFILIATE_LINK=

# -----------------------------------------------------------------------------
# 스케줄러 설정
# -----------------------------------------------------------------------------
# 발행 스케줄 (주 3회: 월, 수, 금 오전 9시)
SCHEDULE_DAYS=mon,wed,fri
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0

# 자동 발행 모드 (true면 검토 없이 자동 발행)
AUTO_PUBLISH=false

# -----------------------------------------------------------------------------
# 로깅 설정
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# SSL 인증서 설정 (Let's Encrypt)
# -----------------------------------------------------------------------------
SSL_EMAIL=ssl@your-domain.com
DOMAIN_NAME=your-domain.com

# -----------------------------------------------------------------------------
# Flask 앱 보안 키
# -----------------------------------------------------------------------------
SECRET_KEY=여기에_랜덤_시크릿_키_입력_변경하세요